<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="900" prefHeight="620" styleClass="dialog-pane" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eagle.plugin.builtin.ThreeDViewerController">

    <top>
        <VBox spacing="8" styleClass="wizard-header">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label text="3D Object Viewer" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label text="Load and control 3D models (glTF/GLB, OBJ, STL) — Drag to rotate, scroll to zoom, right-drag to pan" style="-fx-font-size: 11px; -fx-text-fill: -text-muted;" />
        </VBox>
    </top>

    <center>
        <VBox fx:id="viewerContainer" spacing="6">
            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
        </VBox>
    </center>

    <bottom>
        <VBox spacing="6" styleClass="wizard-footer">
            <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>

            <!-- File row -->
            <HBox spacing="6" alignment="CENTER_LEFT">
                <ComboBox fx:id="modelFormatChoice" prefWidth="140" />
                <TextField fx:id="filePathField" promptText="Select a 3D model file..." HBox.hgrow="ALWAYS" />
                <Button fx:id="browseBtn" text="Browse" onAction="#onBrowse" />
                <Button fx:id="loadBtn" text="Load" onAction="#onLoad" defaultButton="true" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
            </HBox>

            <!-- Controls row -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <CheckBox fx:id="wireframeCheck" text="Wireframe" onAction="#onWireframeToggle" />
                <Label text="Color:" />
                <ColorPicker fx:id="colorPicker" onAction="#onColorChange" />
                <Label text="Background:" />
                <ColorPicker fx:id="bgColorPicker" onAction="#onBgColorChange" />
                <Button fx:id="resetCameraBtn" text="Reset Camera" onAction="#onResetCamera" />
                <Label fx:id="statusLabel" text="Ready" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px; -fx-text-fill: -text-muted;" />
                <Button fx:id="closeBtn" text="Close" onAction="#onClose" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
