<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootPane" prefWidth="640" prefHeight="500" styleClass="welcome-root"
      stylesheets="@../css/base.css"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.eagle.controller.CommandPaletteController">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <Label text="Command Palette" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
    <Label text="Search commands, snippets, and editor actions across all languages"
           style="-fx-text-fill: -text-secondary; -fx-font-size: 11px;"/>
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <padding><Insets top="10"/></padding>
        <TextField fx:id="searchField" promptText="Type to filter (e.g. flex, loop, save, git, doctype, grid...)"/>
        <ListView fx:id="commandList" VBox.vgrow="ALWAYS"/>
        <Label text="↑↓ navigate • Enter to select • Esc to close"
               style="-fx-text-fill: -text-tertiary; -fx-font-size: 10px;"/>
    </VBox>
</VBox>
