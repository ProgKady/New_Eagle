<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.layout.Region?>

<BorderPane fx:id="rootPane" styleClass="main-container" stylesheets="@../css/base.css"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.eagle.controller.BuilderController">

    <top>
        <VBox>
            <!-- Menu Bar -->
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="New Project" onAction="#onNewProject"/>
                    <MenuItem text="Open Project" onAction="#onOpenProject"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Save" onAction="#onSave" accelerator="Ctrl+S"/>
                    <MenuItem text="Preview in Browser" onAction="#onPreview" accelerator="F12"/>
                    <MenuItem text="Export HTML" onAction="#onViewCode"/>
                    <MenuItem text="Export ZIP" onAction="#onExportZip"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#onExit"/>
                </Menu>
                <Menu text="Edit">
                    <MenuItem text="Undo" onAction="#onUndo" accelerator="Ctrl+Z"/>
                    <MenuItem text="Redo" onAction="#onRedo" accelerator="Ctrl+Y"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Copy" onAction="#onCopy" accelerator="Ctrl+C"/>
                    <MenuItem text="Paste" onAction="#onPaste" accelerator="Ctrl+V"/>
                    <MenuItem text="Duplicate" onAction="#onDuplicate" accelerator="Ctrl+D"/>
                    <MenuItem text="Delete" onAction="#onDeleteSelected" accelerator="Del"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Select All" onAction="#onSelectAllFromMenu" accelerator="Ctrl+A"/>
                    <MenuItem text="Clear Canvas" onAction="#onClearCanvas"/>
                </Menu>
                <Menu text="View">
                    <MenuItem text="Zoom In" onAction="#onZoomIn" accelerator="Ctrl+PLUS"/>
                    <MenuItem text="Zoom Out" onAction="#onZoomOut" accelerator="Ctrl+-"/>
                    <MenuItem text="Reset Zoom" onAction="#onZoomReset"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Toggle Snap Grid" onAction="#onToggleSnap"/>
                    <MenuItem text="Toggle Smart Guides" onAction="#onToggleGuides"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About Builder" onAction="#onAbout"/>
                </Menu>
            </MenuBar>

            <!-- Toolbar 1 - Main Actions -->
            <HBox alignment="CENTER_LEFT" spacing="4" styleClass="toolbar-container">
                <padding><Insets top="6" right="10" bottom="6" left="10"/></padding>

                <Button text="Save" styleClass="btn-icon toolbar-save" onAction="#onSave"/>
                <Button text="Undo" styleClass="btn-icon toolbar-undo" onAction="#onUndo"/>
                <Button text="Redo" styleClass="btn-icon toolbar-redo" onAction="#onRedo"/>
                <Separator orientation="VERTICAL"/>
                <Button text="Clear" styleClass="btn-icon" onAction="#onClearCanvas"/>
                <Separator orientation="VERTICAL"/>
                <Button text="Code" styleClass="btn-icon" onAction="#onViewCode"/>
                <Button text="Preview" styleClass="btn-icon toolbar-preview" onAction="#onPreview"/>
                <Button text="ZIP" styleClass="btn-icon toolbar-quick-apk" onAction="#onExportZip"/>

                <Separator orientation="VERTICAL"/>
                <Button text="Copy" styleClass="btn-icon menu-copy" onAction="#onCopy"/>
                <Button text="Paste" styleClass="btn-icon menu-paste" onAction="#onPaste"/>
                <Button text="Duplicate" styleClass="btn-icon" onAction="#onDuplicate"/>

                <HBox HBox.hgrow="ALWAYS"/>

                <Label text="Zoom:" style="-fx-font-size: 11px;"/>
                <Button text="−" styleClass="btn-small" onAction="#onZoomOut"/>
                <Slider fx:id="zoomSlider" min="25" max="200" value="100" blockIncrement="10"
                        majorTickUnit="50" showTickLabels="true" snapToTicks="false"
                        prefWidth="100" style="-fx-font-size: 10px;"/>
                <Button text="+" styleClass="btn-small" onAction="#onZoomIn"/>
                <Label fx:id="zoomLabel" text="100%" style="-fx-font-size: 11px; -fx-min-width: 40;"/>

                <Separator orientation="VERTICAL"/>
                <StackPane fx:id="themeTogglePane" styleClass="theme-toggle" onMouseClicked="#onToggleTheme">
                    <Circle fx:id="toggleKnob" styleClass="theme-toggle-knob" radius="10" translateX="-12"/>
                </StackPane>
            </HBox>

            <!-- Toolbar 2 - Alignment & Editing -->
            <HBox alignment="CENTER_LEFT" spacing="4" styleClass="toolbar-container" style="-fx-background-color: derive(-bg-primary, -5%); -fx-padding: 3 10;">
                <Button text="⬅ Align L" styleClass="btn-small" onAction="#onAlignLeft"/>
                <Button text="⬌ Center" styleClass="btn-small" onAction="#onAlignCenter"/>
                <Button text="➡ Align R" styleClass="btn-small" onAction="#onAlignRight"/>
                <Separator orientation="VERTICAL"/>
                <Button text="⬆ Top" styleClass="btn-small" onAction="#onAlignTop"/>
                <Button text="⬌ Middle" styleClass="btn-small" onAction="#onAlignMiddle"/>
                <Button text="⬇ Bottom" styleClass="btn-small" onAction="#onAlignBottom"/>
                <Separator orientation="VERTICAL"/>
                <Button text="⬆ Front" styleClass="btn-small" onAction="#onBringToFront"/>
                <Button text="⬇ Back" styleClass="btn-small" onAction="#onSendToBack"/>
                <Separator orientation="VERTICAL"/>
                <Button text="⌗ Duplicate" styleClass="btn-small" onAction="#onDuplicate"/>
                <Button text="✕ Delete" styleClass="btn-small" onAction="#onDeleteSelected"/>
                <Separator orientation="VERTICAL"/>
                <CheckBox fx:id="snapGridCheck" text="Snap" selected="true" style="-fx-font-size: 11px;"/>
                <CheckBox fx:id="smartGuidesCheck" text="Guides" selected="true" style="-fx-font-size: 11px;"/>

                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="projectNameLabel" text="" style="-fx-font-weight: bold; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane fx:id="mainSplit" dividerPositions="0.22, 0.78">
            <items>
                <!-- Left Sidebar: Palette + Layers + Component Tree -->
                <VBox styleClass="sidebar" minWidth="180" prefWidth="240">
                    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <Tab text="Components">
                            <VBox>
                                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                                    <VBox fx:id="paletteBox" spacing="6">
                                        <padding><Insets top="6" right="8" bottom="10" left="8"/></padding>
                                    </VBox>
                                </ScrollPane>
                            </VBox>
                        </Tab>
                        <Tab text="Layers">
                            <VBox>
                                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                                    <VBox fx:id="layersBox" spacing="2">
                                        <padding><Insets top="6" right="8" bottom="10" left="8"/></padding>
                                    </VBox>
                                </ScrollPane>
                            </VBox>
                        </Tab>
                        <Tab text="Tree">
                            <VBox>
                                <TreeView fx:id="componentTree" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;"/>
                            </VBox>
                        </Tab>
                    </TabPane>
                </VBox>

                <!-- Canvas - Pane for Free Move with absolute positioning -->
                <ScrollPane fx:id="canvasScroll" fitToWidth="false" fitToHeight="false"
                            hbarPolicy="ALWAYS" vbarPolicy="ALWAYS"
                            styleClass="canvas-scroll">
                    <StackPane>
                        <!-- Grid overlay -->
                        <Pane fx:id="gridPane" mouseTransparent="true" pickOnBounds="false"/>
                        <!-- Main canvas for components -->
                        <Pane fx:id="canvas" minWidth="4000" minHeight="4000"
                              style="-fx-background-color: #f0f0f0;"/>
                        <!-- Selection rectangle overlay -->
                        <Pane fx:id="selectionRectPane" mouseTransparent="true" pickOnBounds="false"/>
                        <!-- Smart guides overlay -->
                        <Pane fx:id="guidesPane" mouseTransparent="true" pickOnBounds="false"/>
                        <!-- Resize handles overlay -->
                        <Pane fx:id="handlesPane" mouseTransparent="false" pickOnBounds="false"/>
                    </StackPane>
                </ScrollPane>

                <!-- Right Sidebar: Properties -->
                <VBox styleClass="sidebar" minWidth="220" prefWidth="280">
                    <Label text="PROPERTIES" style="-fx-font-size: 11px; -fx-font-weight: bold;">
                        <padding><Insets top="10" left="12" bottom="6"/></padding>
                    </Label>
                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                        <VBox fx:id="propertiesBox" spacing="10">
                            <padding><Insets top="6" right="12" bottom="10" left="12"/></padding>
                        </VBox>
                    </ScrollPane>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="status-bar">
            <Label fx:id="statusLabel" text="Drag a component onto the canvas to begin"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="posLabel" text="X: 0  Y: 0" style="-fx-font-size: 10px; -fx-text-fill: -text-muted;"/>
        </HBox>
    </bottom>

</BorderPane>
