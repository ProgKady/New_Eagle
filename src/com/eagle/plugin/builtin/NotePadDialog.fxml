<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefWidth="550" prefHeight="450" styleClass="dialog-pane" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.eagle.plugin.builtin.NotePadController">

    <top>
        <VBox spacing="8" styleClass="wizard-header">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label text="NotePad" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label text="Type your notes below. They stay even after closing." style="-fx-font-size: 11px; -fx-text-fill: -text-muted;" />
        </VBox>
    </top>

    <center>
        <VBox spacing="8">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <TextArea fx:id="noteArea" promptText="Write something..." VBox.vgrow="ALWAYS" />
        </VBox>
    </center>

    <bottom>
        <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="wizard-footer">
            <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
            <Label fx:id="statusLabel" text="Ready" HBox.hgrow="ALWAYS" style="-fx-font-size: 11px; -fx-text-fill: -text-muted;" />
            <Button text="Clear" onAction="#onClear" />
            <Button text="Copy" onAction="#onCopy" />
            <Button text="Close" onAction="#onClose" defaultButton="true" />
        </HBox>
    </bottom>
</BorderPane>
